    },
    "value-proposition-canvas": {
      "en": "ERIC moves (Eliminate / Reduce / Raise / Create) translate directly into VPC's Pain Relievers and Gain Creators.",
      "zh": "ERIC 动作(剔除 / 减少 / 提升 / 创造)直接对应 VPC 的痛点缓解和收益创造。"
    }
  }
