apps/cli/build/
*.dmg
*.zip
*.blockmap

# Dev runtime data (must never enter installer)
apps/server/data/

# Dev logs & PIDs
.dev/
*.log

# Local secrets
.env
.env.*
!.env.example

# OS
.DS_Store
