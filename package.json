{
  "name": "pingarden",
  "version": "0.6.0",
  "private": true,
  "description": "Self-hostable, real-time collaborative tool for Strategyzer-style strategy canvases",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "./start.sh",
    "stop": "./stop.sh",
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @pingarden/server run dev",
    "dev:web": "pnpm --filter @pingarden/web run dev",
    "build": "pnpm -r run build",
    "build:desktop": "bash ./scripts/package-mac.sh",
    "dist": "pnpm build:desktop",
    "package:mac": "bash ./scripts/package-mac.sh",
    "build:skill-pack": "pnpm --filter @pingarden/cli run build && node apps/cli/dist/index.js skill install --local && node scripts/build-skill-pack.mjs",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "smoke:cloud": "node scripts/cloud-smoke-test.mjs",
    "check:cloud-release": "node scripts/cloud-release-check.mjs",
    "benchmark:copilot": "node scripts/copilot-latency-benchmark.mjs",
    "smoke:mobile": "node scripts/mobile-ui-smoke.mjs",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.5.0"
}
